{
  "name": "@adeficior/windpunk",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "serve": "packwiz serve --pack-file .assembler/pack/pack.toml",
    "assemble": "assembler --generate --merge",
    "download": "docker compose up installer --build --abort-on-container-exit",
    "dump": "docker compose up dump --build --abort-on-container-exit",
    "upload": "assembler publish",
    "prepare": "husky && assembler prepare"
  },
  "dependencies": {
    "@adeficior/assembler": "^1.0.0-rc.27"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "typescript": "^5"
  }
}